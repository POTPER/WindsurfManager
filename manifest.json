{
  "manifest_version": 3,
  "name": "Windsurf Account Manager",
  "description": "Manage Windsurf accounts, monitor usage quotas and switch sessions.",
  "version": "0.1.0",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": [
    "https://windsurf.com/*",
    "https://*.windsurf.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Windsurf Account Manager"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
